PORT=3000
HOST_PORT=3001
MCV_CLIENT_ID=your-client-id
MCV_CLIENT_SECRET=your-client-secret
# Must exactly match the URL registered with MyCourseVille.
# Examples:
# MCV_REDIRECT_URI=https://cedt-ices.com/
# MCV_REDIRECT_URI=https://cedt-ies.cp.eng.chula.ac.th/
# MCV_REDIRECT_URI=http://localhost:3000/oauth/callback
MCV_REDIRECT_URI=https://cedt-ices.com/

# Public path used to open the app. This is independent from MCV_REDIRECT_URI.
APP_BASE_PATH=/playground
MCV_SCOPE=public
